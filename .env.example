# Copy to .env and fill in values:
#   copy .env.example .env
#
# Docker Compose automatically loads .env from this directory.

# Optional bearer key for the local OpenAI-compatible proxy.
# Leave empty to disable auth (fine for localhost only).
# When set, clients must send: Authorization: Bearer <key>
TABBIT_SERVER_API_KEY=

# Optional path override for tabbit_client / openai_server (native Python runs).
# Docker Compose mounts ./tabbit_config.json instead of using this.
# TABBIT_CONFIG=./tabbit_config.json
